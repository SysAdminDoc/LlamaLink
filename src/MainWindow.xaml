<Window x:Class="LlamaLink.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="LlamaLink" Width="1300" Height="900"
        Background="{StaticResource BaseBrush}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        Icon="/llamalink.ico">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarCol" Width="340" MinWidth="280" MaxWidth="440"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ Left Sidebar ═══ -->
        <Border Grid.Column="0" Background="{StaticResource MantleBrush}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Sidebar header -->
                <Border Grid.Row="0" Padding="16,14,16,10">
                    <DockPanel>
                        <Button x:Name="ToggleSidebarBtn" Content="&#xE700;" FontFamily="Segoe MDL2 Assets"
                                Style="{StaticResource GhostButton}" DockPanel.Dock="Right" FontSize="14"
                                Click="ToggleSidebar_Click" ToolTip="Toggle sidebar"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="LlamaLink" FontSize="18" FontWeight="Bold"
                                       Foreground="{StaticResource LavenderBrush}"/>
                            <TextBlock Text=" v0.4.0" FontSize="11" Foreground="{StaticResource Overlay0Brush}"
                                       VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Sidebar content -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="12,0,12,12">
                    <StackPanel>
                        <!-- ── Server ── -->
                        <GroupBox Header="Server">
                            <StackPanel>
                                <CheckBox x:Name="ManagedCheck" Content="Launch server locally" IsChecked="True"
                                          Checked="ManagedCheck_Changed" Unchecked="ManagedCheck_Changed"/>

                                <DockPanel x:Name="ExeRow" Margin="0,8,0,0">
                                    <Button Content="..." DockPanel.Dock="Right" Margin="6,0,0,0"
                                            Click="BrowseExe_Click" Padding="10,5" ToolTip="Browse for llama-server.exe"/>
                                    <TextBox x:Name="ExePathBox" VerticalContentAlignment="Center"/>
                                </DockPanel>

                                <DockPanel x:Name="ExtUrlRow" Margin="0,8,0,0" Visibility="Collapsed">
                                    <TextBox x:Name="ExtUrlBox" Text="http://127.0.0.1:8080" VerticalContentAlignment="Center"/>
                                </DockPanel>

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel x:Name="PortRow" Orientation="Horizontal">
                                        <Label Content="Port"/>
                                        <TextBox x:Name="PortBox" Text="8080" Width="60" Margin="6,0,0,0" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button x:Name="StartBtn" Content="Start" Style="{StaticResource GreenButton}"
                                                Click="StartServer_Click" Padding="14,5"/>
                                        <Button x:Name="ConnectBtn" Content="Connect" Style="{StaticResource MauveButton}"
                                                Click="ConnectExternal_Click" Padding="14,5" Visibility="Collapsed"/>
                                        <Button x:Name="StopBtn" Content="Stop" Style="{StaticResource RedButton}"
                                                Click="StopServer_Click" Margin="6,0,0,0" IsEnabled="False" Padding="14,5"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Status pill -->
                                <Border Margin="0,8,0,0" Padding="8,4" CornerRadius="10"
                                        HorizontalAlignment="Left" Background="{StaticResource CrustBrush}">
                                    <StackPanel Orientation="Horizontal">
                                        <Ellipse x:Name="ServerDot" Width="8" Height="8" Margin="0,0,6,0">
                                            <Ellipse.Fill>
                                                <SolidColorBrush Color="{StaticResource CatRed}"/>
                                            </Ellipse.Fill>
                                        </Ellipse>
                                        <TextBlock x:Name="ServerStatusLabel" Text="Stopped" FontSize="11"
                                                   Foreground="{StaticResource Subtext0Brush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </GroupBox>

                        <!-- ── Model ── -->
                        <GroupBox x:Name="ModelGroup" Header="Model">
                            <StackPanel>
                                <DockPanel>
                                    <Button Content="..." DockPanel.Dock="Right" Margin="6,0,0,0"
                                            Click="BrowseModelFolder_Click" Padding="10,5" ToolTip="Browse for model folder"/>
                                    <TextBox x:Name="ModelFolderBox" TextChanged="ModelFolder_Changed" VerticalContentAlignment="Center"/>
                                </DockPanel>
                                <ComboBox x:Name="ModelCombo" Margin="0,6,0,0" SelectionChanged="ModelCombo_Changed"/>
                                <TextBlock x:Name="ModelInfoLabel" Foreground="{StaticResource Overlay0Brush}"
                                           FontSize="11" Margin="2,4,0,0"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- ── Server Params ── -->
                        <GroupBox x:Name="ServerParamsGroup" Header="Server Parameters">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Label Content="Context" ToolTip="Context window size in tokens"/>
                                <TextBox x:Name="CtxBox" Text="4096" Grid.Column="1" Margin="8,2" VerticalContentAlignment="Center"/>
                                <Label Content="GPU Layers" Grid.Row="1" ToolTip="Number of layers to offload to GPU"/>
                                <TextBox x:Name="GpuBox" Text="99" Grid.Row="1" Grid.Column="1" Margin="8,2" VerticalContentAlignment="Center"/>
                                <Label Content="Threads" Grid.Row="2" ToolTip="CPU threads for inference"/>
                                <TextBox x:Name="ThreadsBox" Text="4" Grid.Row="2" Grid.Column="1" Margin="8,2" VerticalContentAlignment="Center"/>
                                <CheckBox x:Name="FlashAttnCheck" Content="Flash Attention" IsChecked="True" Grid.Row="3" Grid.ColumnSpan="2" Margin="0,6,0,0"/>
                                <CheckBox x:Name="MlockCheck" Content="Memory Lock" Grid.Row="4" Grid.ColumnSpan="2" Margin="0,4,0,0"/>
                            </Grid>
                        </GroupBox>

                        <!-- ── Generation ── -->
                        <GroupBox Header="Generation">
                            <StackPanel>
                                <DockPanel Margin="0,2">
                                    <TextBlock x:Name="TempLabel" Text="0.70" Width="32" DockPanel.Dock="Right"
                                               Foreground="{StaticResource LavenderBrush}" FontWeight="SemiBold"
                                               TextAlignment="Right" FontSize="12"/>
                                    <Label Content="Temperature"/>
                                    <Slider x:Name="TempSlider" Minimum="0" Maximum="200" Value="70"
                                            ValueChanged="TempSlider_Changed" Margin="8,0,6,0"/>
                                </DockPanel>
                                <DockPanel Margin="0,6">
                                    <TextBlock x:Name="TopPLabel" Text="0.90" Width="32" DockPanel.Dock="Right"
                                               Foreground="{StaticResource LavenderBrush}" FontWeight="SemiBold"
                                               TextAlignment="Right" FontSize="12"/>
                                    <Label Content="Top P"/>
                                    <Slider x:Name="TopPSlider" Minimum="0" Maximum="100" Value="90"
                                            ValueChanged="TopPSlider_Changed" Margin="8,0,6,0"/>
                                </DockPanel>
                                <DockPanel Margin="0,2">
                                    <TextBlock x:Name="RepLabel" Text="1.10" Width="32" DockPanel.Dock="Right"
                                               Foreground="{StaticResource LavenderBrush}" FontWeight="SemiBold"
                                               TextAlignment="Right" FontSize="12"/>
                                    <Label Content="Repeat Penalty"/>
                                    <Slider x:Name="RepSlider" Minimum="100" Maximum="200" Value="110"
                                            ValueChanged="RepSlider_Changed" Margin="8,0,6,0"/>
                                </DockPanel>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/><RowDefinition Height="4"/><RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <StackPanel>
                                        <Label Content="Top K" FontSize="11"/>
                                        <TextBox x:Name="TopKBox" Text="40" Margin="0,2,4,0" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <Label Content="Max Tokens" FontSize="11"/>
                                        <TextBox x:Name="MaxTokensBox" Text="2048" Margin="4,2,0,0" VerticalContentAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.ColumnSpan="2">
                                        <Label Content="Preset" FontSize="11"/>
                                        <ComboBox x:Name="PresetCombo" Margin="0,2,0,0" SelectionChanged="Preset_Changed">
                                            <ComboBoxItem Content="Default" IsSelected="True"/>
                                            <ComboBoxItem Content="Creative"/>
                                            <ComboBoxItem Content="Precise"/>
                                            <ComboBoxItem Content="Code"/>
                                            <ComboBoxItem Content="Roleplay"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </GroupBox>

                        <!-- ── System Prompt ── -->
                        <GroupBox Header="System Prompt">
                            <TextBox x:Name="SystemPromptBox" AcceptsReturn="True" TextWrapping="Wrap"
                                     Height="60" VerticalScrollBarVisibility="Auto"/>
                        </GroupBox>

                        <!-- ── Chat History ── -->
                        <GroupBox Header="History">
                            <StackPanel>
                                <ListBox x:Name="HistoryList" Height="110" SelectionChanged="History_Selected"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Content="Export" Click="ExportChat_Click" Style="{StaticResource GhostButton}"/>
                                    <Button Content="Delete" Click="DeleteChat_Click" Style="{StaticResource GhostButton}"
                                            Foreground="{StaticResource RedBrush}" Margin="4,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>

                <!-- Sidebar footer / status -->
                <Border Grid.Row="2" Padding="16,8" BorderThickness="0,1,0,0"
                        BorderBrush="{StaticResource Surface0Brush}">
                    <TextBlock x:Name="StatusLabel" Text="Configure server and model to begin"
                               Foreground="{StaticResource Overlay0Brush}" FontSize="11" TextTrimming="CharacterEllipsis"/>
                </Border>
            </Grid>
        </Border>

        <!-- ═══ Splitter ═══ -->
        <GridSplitter Grid.Column="1" Width="1" HorizontalAlignment="Center"
                      Background="{StaticResource Surface0Brush}"/>

        <!-- ═══ Main Content ═══ -->
        <TabControl Grid.Column="2" x:Name="MainTabs" Padding="0">
            <!-- ── Chat Tab ── -->
            <TabItem Header="Chat">
                <Grid Margin="0,4,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Chat display -->
                    <ScrollViewer x:Name="ChatScroll" VerticalScrollBarVisibility="Auto" Padding="12,8">
                        <ItemsControl x:Name="ChatMessages">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,3" Padding="14,10" CornerRadius="8"
                                            Background="{Binding Background}"
                                            BorderThickness="0,0,0,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="{Binding RoleLabel}" Foreground="{Binding Accent}"
                                                       FontWeight="SemiBold" FontSize="11" Margin="0,0,0,4"/>
                                            <TextBlock Grid.Row="1" Text="{Binding Content}" TextWrapping="Wrap"
                                                       FontSize="13.5" Foreground="{StaticResource TextBrush}"
                                                       FontFamily="Segoe UI" LineHeight="20"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Empty state overlay -->
                    <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="Visible">
                        <TextBlock Text="&#xE8BD;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                                   Foreground="{StaticResource Surface1Brush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Start a conversation" FontSize="16" Foreground="{StaticResource Overlay0Brush}"
                                   HorizontalAlignment="Center" Margin="0,12,0,4"/>
                        <TextBlock Text="Configure your server and model in the sidebar, then type a message below."
                                   FontSize="12" Foreground="{StaticResource Surface2Brush}" HorizontalAlignment="Center"
                                   TextWrapping="Wrap" TextAlignment="Center" MaxWidth="360"/>
                    </StackPanel>

                    <!-- Input area -->
                    <Border Grid.Row="1" Margin="12,0,12,12" Background="{StaticResource MantleBrush}"
                            CornerRadius="12" BorderBrush="{StaticResource Surface0Brush}" BorderThickness="1"
                            Padding="4">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBox x:Name="InputBox" AcceptsReturn="True" TextWrapping="Wrap"
                                     MaxHeight="120" VerticalScrollBarVisibility="Auto"
                                     Background="Transparent" BorderThickness="0" FontSize="13.5"
                                     KeyDown="InputBox_KeyDown" Padding="10,8"
                                     VerticalContentAlignment="Top"/>

                            <DockPanel Grid.Row="1" Margin="8,0,4,4">
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                    <TextBlock x:Name="SpeedLabel" Foreground="{StaticResource PeachBrush}"
                                               FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"
                                               Margin="0,0,8,0"/>
                                    <TextBlock x:Name="TokenCountLabel" Foreground="{StaticResource Overlay0Brush}"
                                               FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Button x:Name="StopGenBtn" Content="Stop" Style="{StaticResource RedButton}"
                                            Height="30" Click="StopGen_Click" Visibility="Collapsed" Padding="12,4"/>
                                    <Button x:Name="SendBtn" Style="{StaticResource AccentButton}"
                                            Height="30" Click="Send_Click" Padding="16,4">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Send" VerticalAlignment="Center"/>
                                            <TextBlock Text=" &#xE724;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                                       VerticalAlignment="Center" Margin="4,0,0,0"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                                <Button Content="New Chat" Click="NewChat_Click" Style="{StaticResource GhostButton}"
                                        VerticalAlignment="Center"/>
                            </DockPanel>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ── Download Models Tab ── -->
            <TabItem Header="Download Models">
                <Grid Margin="12,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Search bar -->
                    <Border Background="{StaticResource MantleBrush}" CornerRadius="8" Padding="4">
                        <DockPanel>
                            <Button x:Name="HfSearchBtn" Content="Search" Style="{StaticResource AccentButton}"
                                    DockPanel.Dock="Right" Margin="4,0,0,0" Height="32" Click="HfSearch_Click" Padding="16,4"/>
                            <TextBox x:Name="HfSearchBox" FontSize="13" VerticalContentAlignment="Center"
                                     KeyDown="HfSearchBox_KeyDown" Background="Transparent" BorderThickness="0"
                                     Padding="8,6"/>
                        </DockPanel>
                    </Border>

                    <!-- Sort row -->
                    <DockPanel Grid.Row="1" Margin="0,8,0,4">
                        <TextBlock x:Name="HfResultCount" DockPanel.Dock="Right"
                                   Foreground="{StaticResource Overlay0Brush}" FontSize="11" VerticalAlignment="Center"/>
                        <Label Content="Sort"/>
                        <ComboBox x:Name="HfSortCombo" Width="160" Margin="6,0,0,0"
                                  SelectionChanged="HfSort_Changed">
                            <ComboBoxItem Content="Most Downloads" Tag="downloads" IsSelected="True"/>
                            <ComboBoxItem Content="Most Likes" Tag="likes"/>
                            <ComboBoxItem Content="Recently Updated" Tag="lastModified"/>
                            <ComboBoxItem Content="Trending" Tag="trending_score"/>
                        </ComboBox>
                    </DockPanel>

                    <!-- Model results grid -->
                    <DataGrid x:Name="HfModelGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single" CanUserSortColumns="True"
                              SelectionChanged="HfModel_Selected">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Model" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Author" Binding="{Binding Author}" Width="120"/>
                            <DataGridTextColumn Header="Downloads" Binding="{Binding DownloadsDisplay}" Width="100"/>
                            <DataGridTextColumn Header="Likes" Binding="{Binding LikesDisplay}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <GridSplitter Grid.Row="3" Height="3" HorizontalAlignment="Stretch"
                                  Background="Transparent" Margin="0,4"/>

                    <!-- Files grid -->
                    <DockPanel Grid.Row="4">
                        <TextBlock x:Name="HfFilesLabel" DockPanel.Dock="Top"
                                   Text="Select a model to see GGUF files"
                                   Foreground="{StaticResource Overlay0Brush}" FontSize="12"
                                   FontStyle="Italic" Margin="2,0,0,6"/>
                        <DataGrid x:Name="HfFilesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                                  SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Filename" Binding="{Binding Filename}" Width="*"/>
                                <DataGridTextColumn Header="Quant" Binding="{Binding Quant}" Width="90"/>
                                <DataGridTextColumn Header="Size" Binding="{Binding SizeDisplay}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>

                    <!-- Download controls -->
                    <DockPanel Grid.Row="5" Margin="0,8,0,0">
                        <TextBlock x:Name="DlDestLabel" DockPanel.Dock="Right" VerticalAlignment="Center"
                                   Foreground="{StaticResource Overlay0Brush}" FontSize="11"/>
                        <Button x:Name="DlBtn" Content="Download" Style="{StaticResource GreenButton}"
                                Height="32" Click="HfDownload_Click" Padding="16,4"/>
                        <Button x:Name="DlCancelBtn" Content="Cancel" Style="{StaticResource RedButton}"
                                Height="32" Margin="6,0,0,0" Click="HfCancelDownload_Click" Visibility="Collapsed" Padding="16,4"/>
                    </DockPanel>

                    <ProgressBar x:Name="DlProgress" Grid.Row="6" Margin="0,8,0,0" Visibility="Collapsed"/>

                    <TextBlock x:Name="DlStatusLabel" Grid.Row="7" Margin="2,6,0,0"
                               Foreground="{StaticResource Overlay0Brush}" FontSize="11"/>
                </Grid>
            </TabItem>

            <!-- ── Server Log Tab ── -->
            <TabItem Header="Server Log">
                <Border Background="{StaticResource CrustBrush}" Margin="0,4,0,0" CornerRadius="8">
                    <TextBox x:Name="ServerLogBox" IsReadOnly="True" TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto" Background="Transparent"
                             Foreground="{StaticResource GreenBrush}" FontFamily="Cascadia Code,Consolas,monospace"
                             FontSize="11.5" BorderThickness="0" Padding="12,10"/>
                </Border>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
